# Environment template for production deployment
# Copy as .env and fill in with your values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-min-32-chars
DEBUG=False

# Database
DATABASE_URL=postgresql://phishing:password@localhost:5432/phishing_db
DB_PASSWORD=your-db-password-here

# Server
PORT=5000
WORKERS=4

# Logging
LOG_LEVEL=INFO

# Security
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Email Notifications (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=True

# Sentry Error Tracking (Optional)
SENTRY_DSN=https://your-sentry-url

# AWS S3 Storage (Optional - for uploaded files/models)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_S3_BUCKET=your-bucket
